# ============================================================
# The Witness Protocol Foundation — Platform Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# -- Supabase --
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# -- OpenRouter (Multi-Model LLM Gateway) --
# Sign up at https://openrouter.ai — provides access to Claude, GPT, Gemini, etc.
OPENROUTER_API_KEY=sk-or-v1-xxxx

# -- Resend (Transactional Email) --
# Sign up at https://resend.com
RESEND_API_KEY=re_xxxx

# -- Sentry (Error Monitoring) --
# NOTE: Two variables required — client uses NEXT_PUBLIC_ prefix, server uses plain.
# Both should point to the same DSN value.
# Sign up at https://sentry.io — EU data region recommended.
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.de.sentry.io/xxxx
SENTRY_DSN=https://xxxx@xxxx.ingest.de.sentry.io/xxxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=javascript-nextjs
# SENTRY_AUTH_TOKEN=sntrys_xxxx  # Required for source map uploads (create at sentry.io/settings/auth-tokens/)

# -- Provenance (Phase 4+) --
# DIGISTAMP_USERNAME=
# DIGISTAMP_PASSWORD=
# PINATA_API_KEY=
# PINATA_SECRET_KEY=

# -- App Config --
NEXT_PUBLIC_APP_URL=https://thewprotocol.online
NEXT_PUBLIC_STAGE=pre-alpha
